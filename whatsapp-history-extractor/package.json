{
  "name": "whatsapp-history-extractor",
  "version": "1.0.0",
  "description": "One-time historical PDF extractor for WhatsApp using Baileys (protocol-level, no browser)",
  "type": "commonjs",
  "scripts": {
    "extract": "ts-node --project tsconfig.json src/extract.ts",
    "parse-export": "ts-node --project tsconfig.json src/parseExportZip.ts",
    "build": "tsc",
    "start": "node dist/extract.js"
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/qrcode-terminal": "^0.12.2",
    "@whiskeysockets/baileys": "^6.7.9",
    "adm-zip": "^0.5.17",
    "pino": "^8.21.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^20.12.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
