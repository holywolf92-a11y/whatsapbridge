NODE_ENV=production
LOG_LEVEL=info
HEALTH_PORT=4310

# Phase 1 uses the existing Falisha Meta intake flow.
BRIDGE_MODE=meta-forward
API_WHATSAPP_NUMBER=923001234567@c.us

# Keep limits conservative during pilot.
MAX_FILE_SIZE_MB=10
ALLOWED_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,image/jpeg,image/png

# Keep replies off during pilot.
AUTO_REPLY_ENABLED=false
AUTO_REPLY_MESSAGE=Your CV has been received. Thank you.

# Local single-instance stores.
DEDUP_STORE_PATH=./data/dedupe-store.json
ACCOUNT_CONTROL_PATH=./data/account-controls.json

# Use file-based account inventory for rollout control.
BRIDGE_ACCOUNTS_PATH=./config/accounts.pilot.json

# Not used in meta-forward mode.
BACKEND_UPLOAD_URL=
BACKEND_UPLOAD_TOKEN=