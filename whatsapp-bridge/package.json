{
  "name": "falisha-whatsapp-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Controlled WhatsApp bridge for Falisha CV ingestion",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "check:config": "tsx src/scripts/checkConfig.ts",
    "account:pause": "tsx src/scripts/setAccountPaused.ts pause",
    "account:resume": "tsx src/scripts/setAccountPaused.ts resume",
    "account:status": "tsx src/scripts/accountControlStatus.ts",
    "backfill:pdf": "tsx src/scripts/backfillPdfHistory.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "pino": "^9.7.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.34.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^20.17.30",
    "@types/qrcode": "^1.5.5",
    "@types/qrcode-terminal": "^0.12.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}