# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Server
PORT=4000
NODE_ENV=development

# Hostinger Email (support@falishajobs.com)
HOSTINGER_SMTP_USER=support@falishajobs.com
HOSTINGER_SMTP_PASSWORD=

# Hostinger IMAP inbox polling (recommended for inbound candidate replies)
HOSTINGER_IMAP_HOST=imap.hostinger.com
HOSTINGER_IMAP_PORT=993
HOSTINGER_IMAP_SECURE=true
HOSTINGER_IMAP_USER=support@falishajobs.com
HOSTINGER_IMAP_PASSWORD=
RUN_HOSTINGER_POLLING=false

# Canonical "From" address (enforced in code)
EMAIL_FROM=support@falishajobs.com

# Resend (recommended for production on Railway)
RESEND_API_KEY=

# Legacy Gmail polling path (keep disabled if using direct Hostinger inbox polling)
RUN_GMAIL_POLLING=false
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Optional
OPENAI_API_KEY=
PYTHON_CV_PARSER_URL=https://recruitment-python-parser-production.up.railway.app
PYTHON_HMAC_SECRET=
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_APP_SECRET=your_app_secret_here
WEBHOOK_VERIFY_TOKEN=your_verify_token_here
