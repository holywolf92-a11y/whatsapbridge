{
  "name": "falisha-backend",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:worker": "ts-node-dev --respawn --transpile-only src/worker.ts",
    "build": "npx tsc -p tsconfig.json",
    "start:api": "node dist/server.js",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "postinstall": "node -e \"try { if (process.env.PUPPETEER_SKIP_CHROMIUM_DOWNLOAD !== 'true' && require('fs').existsSync('./node_modules/puppeteer/install.js')) { require('puppeteer/install'); } } catch(e) { console.log('Skipping Puppeteer install:', e.message); }\"",
    "lint": "eslint . --ext .ts",
    "test:inbox": "node scripts/testInboxApi.js",
    "test:webhook-security": "node scripts/testWebhookSecurity.js",
    "test:performance": "node scripts/testPerformance.js",
    "test:integration": "node scripts/test-document-verification-integration.js",
    "test:errors": "node scripts/test-document-verification-errors.js",
    "test:all": "npm run test:integration && npm run test:errors",
    "smoke:cv": "node scripts/smoke-cv-parsing.js",
    "smoke:local-queue": "node scripts/smoke-local-queue.js",
    "smoke:whatsapp-bot": "node scripts/smoke-whatsapp-bot-flow-guards.js",
    "test:split-upload": "node scripts/testSplitUpload.js",
    "check-endpoints": "node scripts/checkEndpoints.js",
    "check-endpoints:list": "node scripts/checkEndpoints.js --list"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.93.3",
    "@types/multer": "^2.0.0",
    "@types/nodemailer": "^7.0.9",
    "bullmq": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.0.0",
    "form-data": "^4.0.5",
    "googleapis": "^118.0.0",
    "helmet": "^6.0.0",
    "imapflow": "^1.2.16",
    "ioredis": "^5.3.2",
    "mailparser": "^3.9.4",
    "multer": "^2.0.2",
    "node-fetch": "^2.7.0",
    "nodemailer": "^8.0.0",
    "postgres": "^3.4.8",
    "puppeteer": "^24.36.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.17",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20.0.0",
    "@types/node-fetch": "^2.6.12",
    "@types/uuid": "^10.0.0",
    "pg": "^8.16.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
